{
  "name": "@isubpay/sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "iSub — non-custodial recurring/metered pull-payment primitive on Sui. TS SDK for subscriptions (Fixed), pay-as-you-go (PAYG), x402 mandate scheme, and MCP agent payments.",
  "license": "MIT",
  "homepage": "https://github.com/NBellic10010/iSub/tree/main/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NBellic10010/iSub.git",
    "directory": "sdk"
  },
  "keywords": [
    "sui",
    "payments",
    "subscriptions",
    "metered",
    "pay-as-you-go",
    "x402",
    "mcp",
    "ai-agents",
    "non-custodial",
    "pull-payment",
    "mandate"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./agent": "./src/agent.ts",
    "./biller": "./src/biller.ts",
    "./service": "./src/service.ts",
    "./webhook": "./src/webhook.ts",
    "./store-file": "./src/store-file.ts",
    "./db": "./src/db.ts",
    "./sql-store": "./src/sql-store.ts",
    "./gateway": "./src/gateway.ts",
    "./relations": "./src/relations.ts",
    "./discovery": "./src/discovery.ts",
    "./client": "./src/client-sdk.ts",
    "./mcp": "./src/mcp.ts",
    "./x402": "./src/x402.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsup && node scripts/make-dist-pkg.mjs",
    "release": "npm run build && npm publish ./dist --access public",
    "test:unit": "tsx scripts/unit.ts",
    "publish:localnet": "tsx scripts/publish.ts",
    "smoke": "tsx scripts/smoke.ts",
    "keeper": "tsx scripts/keeper.ts",
    "keeper:smoke": "tsx scripts/keeper-smoke.ts",
    "payg:smoke": "tsx scripts/payg-smoke.ts",
    "dunning:smoke": "tsx scripts/dunning-smoke.ts",
    "idempotency:smoke": "tsx scripts/idempotency-smoke.ts",
    "agent:smoke": "tsx scripts/agent-smoke.ts",
    "pricing:smoke": "tsx scripts/pricing-smoke.ts",
    "rules:smoke": "tsx scripts/rules-smoke.ts",
    "webhook:smoke": "tsx scripts/webhook-smoke.ts",
    "store:smoke": "NODE_OPTIONS=--experimental-sqlite tsx scripts/store-smoke.ts",
    "biller:smoke": "NODE_OPTIONS=--experimental-sqlite tsx scripts/biller-smoke.ts",
    "biller:run": "NODE_OPTIONS=--experimental-sqlite tsx scripts/biller-run.ts",
    "biller-run:testnet": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/biller-run.ts",
    "cortex-serve": "NODE_OPTIONS=--experimental-sqlite tsx scripts/cortex-serve.ts",
    "cortex-serve:testnet": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/cortex-serve.ts",
    "cortex-call": "tsx scripts/cortex-call.ts",
    "relations:smoke": "NODE_OPTIONS=--experimental-sqlite tsx scripts/relations-smoke.ts",
    "relations-http:smoke": "NODE_OPTIONS=--experimental-sqlite tsx scripts/relations-http-smoke.ts",
    "mock:seed": "NODE_OPTIONS=--experimental-sqlite tsx scripts/mock-seed.ts",
    "gateway:serve": "NODE_OPTIONS=--experimental-sqlite tsx scripts/gateway-serve.ts",
    "gateway-serve:testnet": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/gateway-serve.ts",
    "stack": "tsx scripts/run-stack.ts",
    "stack:testnet": "ISUB_NETWORK=testnet tsx scripts/run-stack.ts",
    "scheduler:smoke": "NODE_OPTIONS=--experimental-sqlite tsx scripts/scheduler-smoke.ts",
    "scheduler-e2e": "tsx scripts/scheduler-e2e.ts",
    "scheduler-e2e:testnet": "ISUB_NETWORK=testnet tsx scripts/scheduler-e2e.ts",
    "service:smoke": "tsx scripts/service-smoke.ts",
    "mcp:smoke": "tsx scripts/mcp-smoke.ts",
    "agent-auth:redteam": "tsx scripts/agent-auth-redteam.ts",
    "agent-auth:durable": "NODE_OPTIONS=--experimental-sqlite tsx scripts/agent-auth-durable-smoke.ts",
    "compliance:smoke": "tsx scripts/compliance-smoke.ts",
    "discovery:smoke": "tsx scripts/discovery-smoke.ts",
    "agent-auth-http:redteam": "NODE_OPTIONS=--experimental-sqlite tsx scripts/agent-auth-http-redteam.ts",
    "x402:smoke": "tsx scripts/x402-smoke.ts",
    "x402-exact:smoke": "tsx scripts/x402-exact-smoke.ts",
    "x402-exact-testnet:smoke": "ISUB_NETWORK=testnet tsx scripts/x402-exact-testnet-smoke.ts",
    "x402-agent:smoke": "tsx scripts/x402-agent-smoke.ts",
    "per-route-auth:smoke": "tsx scripts/per-route-auth-smoke.ts",
    "x402-agent:serve": "tsx scripts/isub-x402-agent.ts",
    "isub:claude": "tsx scripts/isub-claude.ts",
    "x402-plan:setup": "ISUB_NETWORK=testnet tsx scripts/x402-plan-setup.ts",
    "token-plan:setup": "ISUB_NETWORK=testnet tsx scripts/token-plan-setup.ts",
    "cortex-token:setup": "ISUB_NETWORK=testnet tsx scripts/cortex-token-plan.ts",
    "isub:claude:token": "ISUB_TOKEN_AGENT=1 ISUB_NETWORK=testnet tsx scripts/isub-claude.ts",
    "token:smoke": "ISUB_NETWORK=testnet tsx scripts/token-agent-smoke.ts",
    "bill": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/bill.ts",
    "backend": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/backend.ts",
    "x402-testnet:setup": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/x402-testnet-setup.ts",
    "x402-testnet:smoke": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/x402-testnet-smoke.ts",
    "isub:claude:testnet": "ISUB_X402_TESTNET=1 ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/isub-claude.ts",
    "wiring:e2e": "tsx scripts/wiring-e2e.ts",
    "wiring-e2e:testnet": "ISUB_NETWORK=testnet tsx scripts/wiring-e2e.ts",
    "managed-e2e": "NODE_OPTIONS=--experimental-sqlite tsx scripts/managed-e2e.ts",
    "managed-e2e:testnet": "ISUB_NETWORK=testnet NODE_OPTIONS=--experimental-sqlite tsx scripts/managed-e2e.ts",
    "reconcile": "tsx scripts/reconcile.ts",
    "probe:testnet": "tsx scripts/grpc-probe.ts",
    "fund:testnet": "ISUB_NETWORK=testnet tsx scripts/fund.ts",
    "publish:testnet": "ISUB_NETWORK=testnet tsx scripts/publish.ts",
    "smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/smoke.ts",
    "keeper:testnet": "ISUB_NETWORK=testnet tsx scripts/keeper.ts",
    "keeper-smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/keeper-smoke.ts",
    "payg-smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/payg-smoke.ts",
    "dunning-smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/dunning-smoke.ts",
    "agent-smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/agent-smoke.ts",
    "pricing-smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/pricing-smoke.ts",
    "rules-smoke:testnet": "ISUB_NETWORK=testnet tsx scripts/rules-smoke.ts",
    "reconcile:testnet": "ISUB_NETWORK=testnet tsx scripts/reconcile.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mysten/sui": "^2.17.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
