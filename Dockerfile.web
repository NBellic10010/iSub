# iSub web (Next.js dashboards + checkout). Build context = repo root (it's an npm-workspace monorepo;
# @isub/web depends on the @isubpay/sdk workspace, which Next transpiles from source — so the WHOLE repo
# must be installed together, not just web/).
#   Railway: new service → Dockerfile path = Dockerfile.web → set env GATEWAY_ORIGIN (the backend's URL)
#   and NEXT_PUBLIC_DOCS_URL (the docs service's URL). BOTH are BUILD-time: NEXT_PUBLIC_* is inlined, and
#   GATEWAY_ORIGIN is baked into next.config's /gw rewrite — so each must be an ARG below, not just a
#   runtime var (a runtime-only GATEWAY_ORIGIN is ignored and /gw falls back to localhost:4100).
FROM node:22-slim AS build
WORKDIR /app
# install all workspaces (manifests first for layer caching)
COPY package.json package-lock.json* ./
COPY web/package.json web/
COPY sdk/package.json sdk/
COPY checkout/package.json checkout/
RUN npm install
COPY . .
# NEXT_PUBLIC_* is inlined at build time → must be present for `next build`. Railway passes the service
# variable to this ARG. Defaults to the placeholder in page.tsx if unset (so set it on the web service).
ARG NEXT_PUBLIC_DOCS_URL
ENV NEXT_PUBLIC_DOCS_URL=${NEXT_PUBLIC_DOCS_URL}
# GATEWAY_ORIGIN is baked into next.config's /gw rewrite at build time → it MUST be present here.
ARG GATEWAY_ORIGIN
ENV GATEWAY_ORIGIN=${GATEWAY_ORIGIN}
RUN npm run build -w @isub/web

FROM node:22-slim
WORKDIR /app
ENV NODE_ENV=production
COPY --from=build /app /app
EXPOSE 3000
# Railway injects PORT; Next binds it on all interfaces.
CMD ["sh", "-c", "npm run start -w @isub/web -- -p ${PORT:-3000} -H 0.0.0.0"]
